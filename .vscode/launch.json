{
  // Use IntelliSense to learn about possible Node.js debug attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch ER Diagram Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "${workspaceFolder}/workspace",
        "--extensionDevelopmentPath=${workspaceFolder}/er-vscode/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/er-vscode/extension/dist/*.js",
        "${workspaceFolder}/node_modules/@eclipse-glsp/**/*.js"
      ],
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://er-vscode/(.+)": "${workspaceFolder}/er-vscode/extension/$1"
      }
    },
    {
      "name": "Launch ER Diagram Extension (External GLSP Server)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "${workspaceFolder}/workspace",
        "--extensionDevelopmentPath=${workspaceFolder}/er-vscode/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/er-vscode/extension/dist/*.js",
        "${workspaceFolder}/node_modules/@eclipse-glsp/**/*.js"
      ],
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack://er-vscode/(.+)": "${workspaceFolder}/er-vscode/extension/$1"
      },
      "env": {
        "ER_SERVER_DEBUG": "true",
        "ER_SERVER_PORT": "5007"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch ER GLSP Server",
      "program": "${workspaceFolder}/er-glsp-server/lib/app.js",
      "env": {
        "NODE_ENV": "development"
      },
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/node_modules/@eclipse-glsp/**/*.js",
        "${workspaceFolder}/er-glsp-server/lib/**/*.js"
      ],
      "args": [
        "--port=5007"
      ],
      "smartStep": true,
      "internalConsoleOptions": "openOnSessionStart",
      "outputCapture": "std"
    }
  ],
  "compounds": [
    {
      "name": "Launch ER Diagram extension with external GLSP Server",
      "configurations": [
        "Launch ER GLSP Server",
        "Launch ER Diagram Extension (External GLSP Server)"
      ]
    }
  ]
}